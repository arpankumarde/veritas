# Veritas - Fact Checking Engine
# Copy this file to .env and fill in values

# Required: Bright Data API token for web search
BRIGHT_DATA_API_TOKEN=

# Optional: Bright Data zone (default: mcp_unlocker)
BRIGHT_DATA_ZONE=mcp_unlocker

# Optional: Anthropic API key (falls back to Claude Code CLI auth)
ANTHROPIC_API_KEY=

# Optional: API authentication key (no auth when unset)
VERITAS_API_KEY=

# Optional: CORS origins for API (default: localhost:3000)
VERITAS_CORS_ORIGINS=

# Optional: Disable WebSocket log events
VERITAS_DISABLE_LOG_EVENTS=

# Optional: Log file path (default: ~/.veritas/veritas.log)
VERITAS_LOG_FILE=

# Optional: Log level (default: DEBUG)
VERITAS_LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql://postgres:1234@localhost:5432/veritas

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
